{
    "id": "com.github.finefindus.eyedropper",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command": "eyedropper",
    "finish-args": [
        "--socket=fallback-x11",
        "--share=ipc",
        "--socket=wayland",
        "--device=dri",
        "--env=G_MESSAGES_DEBUG=none",
        "--env=RUST_BACKTRACE=1"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin"
    },
    "modules": [
        {
            "name": "eyedropper",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/FineFindus/eyedropper/releases/download/v2.2.0/eyedropper-2.2.0.tar.xz",
                    "sha256": "8cb8c4618559595c20d4be5b4bb158e3aac3f913bab5e8dbcf0953976ce92ce4"

                }
            ]
        }
    ]
}
